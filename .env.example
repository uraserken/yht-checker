# ─────────────────────────────────────────────
# TCDD e-Bilet Bot – Konfigürasyon
# Bu dosyayı .env olarak kopyalayın ve doldurun:
#   copy .env.example .env
# ─────────────────────────────────────────────

# Kalkış istasyonu adı (tam ya da kısmi, büyük/küçük harf önemsiz)
# Örnek: Ankara, İstanbul, İzmir, Konya, Eskişehir
DEPARTURE_STATION=Ankara

# Varış istasyonu adı
ARRIVAL_STATION=İstanbul

# Seyahat tarihi  –  GG/AA/YYYY formatında
TRAVEL_DATE=15/05/2025

# İstenen saat aralığı (opsiyonel – boş bırakırsanız tüm saatler taranır)
# Sadece bu saatler arasındaki seferleri bildirir
HOUR_START=08
HOUR_END=20

# Kaç dakikada bir kontrol edilsin? (varsayılan: 5)
CHECK_INTERVAL_MINUTES=5

# Tarayıcı arka planda mı çalışsın? (true = görünmez, false = pencere açılır)
# Sorun çıkarsa false yaparak ne olduğunu izleyebilirsiniz.
HEADLESS=true

# ─────────────────────────────────────────────
# Telegram Bildirimi
# Bot oluşturmak için: https://t.me/BotFather  →  /newbot
# Chat ID için: bota bir mesaj at, ardından
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# E-posta Bildirimi (Gmail önerilen)
# Gmail için "Uygulama Şifresi" oluşturun:
#   Google Hesabı → Güvenlik → 2 Adımlı Doğrulama → Uygulama Şifreleri
# ─────────────────────────────────────────────
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ─────────────────────────────────────────────
# WhatsApp Bildirimi (Callmebot – ücretsiz)
# Kayıt adımları:
#   1. +34 644 82 99 38 numarasına WhatsApp'tan şu mesajı gönderin:
#      "I allow callmebot to send me messages"
#   2. Birkaç saniye içinde size bir API key gelir.
#   3. Aşağıya telefon numaranızı ve API key'i girin.
# ─────────────────────────────────────────────
WHATSAPP_PHONE=+905551234567
WHATSAPP_API_KEY=
